/**app.wxss — Modern Pet Claymorphism**/
page {
  /* Warm coral + modern palette */
  --color-primary: #F97316;
  --color-primary-dark: #EA580C;
  --color-primary-light: #FFF1E6;
  --color-accent: #2563EB;
  --color-accent-light: #EFF6FF;
  --color-success: #22C55E;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-pink: #F472B6;
  --color-mint: #34D399;
  --color-lavender: #A78BFA;
  --color-bg: #FFF7ED;
  --color-card: #FFFFFF;
  --color-text: #7C2D12;
  --color-text-secondary: #A8774E;
  --color-text-hint: #C4A882;
  --color-border: #FDE8D0;
  /* Claymorphism tokens */
  --radius-sm: 20rpx;
  --radius-md: 28rpx;
  --radius-lg: 40rpx;
  --radius-xl: 56rpx;
  --shadow-clay: 6rpx 6rpx 16rpx rgba(249,115,22,0.10), -4rpx -4rpx 12rpx rgba(255,255,255,0.80);
  --shadow-card: 0 8rpx 28rpx rgba(249,115,22,0.08), 0 2rpx 6rpx rgba(249,115,22,0.04);
  --shadow-float: 0 12rpx 36rpx rgba(249,115,22,0.14), 0 2rpx 8rpx rgba(249,115,22,0.06);
  --shadow-inset: inset 2rpx 2rpx 6rpx rgba(249,115,22,0.06), inset -2rpx -2rpx 6rpx rgba(255,255,255,0.70);
  --border-clay: 3rpx solid rgba(255,255,255,0.50);

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'SF Rounded', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-xl);
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(249,115,22,0.30);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(249,115,22,0.20);
}

.btn-secondary {
  background: var(--color-primary-light);
  color: var(--color-primary);
  border: 3rpx solid rgba(249,115,22,0.15);
  border-radius: var(--radius-xl);
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.btn-secondary:active {
  opacity: 0.85;
}

.tag {
  display: inline-block;
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 22rpx;
  padding: 8rpx 22rpx;
  border-radius: var(--radius-xl);
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  font-weight: 600;
  border: 2rpx solid rgba(249,115,22,0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Decorative bubble */
.bubble {
  display: inline-block;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  padding: 12rpx 28rpx;
  border-radius: 28rpx 28rpx 28rpx 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: var(--shadow-clay);
}

/* Colorful tag variants */
.tag-orange  { background: #FFF1E6; color: #EA580C; }
.tag-blue    { background: #EFF6FF; color: #2563EB; }
.tag-pink    { background: #FDF2F8; color: #DB2777; }
.tag-mint    { background: #ECFDF5; color: #059669; }
.tag-yellow  { background: #FFFBEB; color: #D97706; }
.tag-purple  { background: #F5F3FF; color: #7C3AED; }

/* Vant Weapp theme overrides */
page {
  --button-primary-background-color: #F97316;
  --button-primary-border-color: #F97316;
  --tabs-bottom-bar-color: #F97316;
  --tabs-default-color: #F97316;
  --tag-primary-color: #F97316;
  --rate-icon-full-color: #F97316;
  --field-input-text-color: #7C2D12;
  --uploader-upload-background-color: #FFF7ED;
  --progress-color: linear-gradient(90deg, #F97316, #FB923C);
  --loading-spinner-color: #F97316;
  --empty-description-color: #A8774E;
}
