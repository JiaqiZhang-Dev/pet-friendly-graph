/**app.wxss — Cute Pet Claymorphism (Blue-Purple)**/
page {
  /* Blue primary + purple accent palette */
  --color-primary: #3B82F6;
  --color-primary-dark: #2563EB;
  --color-primary-light: #EFF6FF;
  --color-accent: #8B5CF6;
  --color-accent-light: #F5F3FF;
  --color-success: #22C55E;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-pink: #F472B6;
  --color-mint: #34D399;
  --color-lavender: #A78BFA;
  --color-teal: #14B8A6;
  --color-bg: #F8FAFC;
  --color-card: #FFFFFF;
  --color-text: #1E293B;
  --color-text-secondary: #64748B;
  --color-text-hint: #94A3B8;
  --color-border: #E0D8F5;
  /* Bigger, cuter radius */
  --radius-sm: 24rpx;
  --radius-md: 36rpx;
  --radius-lg: 48rpx;
  --radius-xl: 60rpx;
  --radius-full: 999rpx;
  /* Dreamy blue-purple shadows */
  --shadow-clay: 6rpx 6rpx 20rpx rgba(139,92,246,0.08), -4rpx -4rpx 14rpx rgba(255,255,255,0.85);
  --shadow-card: 0 10rpx 32rpx rgba(59,130,246,0.06), 0 2rpx 8rpx rgba(139,92,246,0.05);
  --shadow-float: 0 14rpx 40rpx rgba(59,130,246,0.10), 0 4rpx 10rpx rgba(139,92,246,0.08);
  --shadow-inset: inset 2rpx 2rpx 8rpx rgba(139,92,246,0.05), inset -2rpx -2rpx 8rpx rgba(255,255,255,0.75);
  --border-clay: 2rpx solid rgba(255,255,255,0.55);
  /* Gradient presets — blue to purple */
  --gradient-primary: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  --gradient-card: linear-gradient(145deg, #FFFFFF 0%, #FAF8FF 100%);
  --gradient-page: linear-gradient(180deg, #F5F3FF 0%, #EDE9FE 40%, #F5F3FF 100%);

  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Hiragino Sans GB', 'SF Rounded', 'Noto Sans SC', sans-serif;
  font-size: 28rpx;
  letter-spacing: 0.5rpx;
  color: var(--color-text);
  background: var(--gradient-page);
  box-sizing: border-box;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.card {
  background: var(--gradient-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.btn-primary {
  background: var(--gradient-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.30);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(59,130,246,0.20);
}

.btn-secondary {
  background: var(--color-primary-light);
  color: var(--color-primary);
  border: 3rpx solid rgba(59,130,246,0.15);
  border-radius: var(--radius-full);
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.btn-secondary:active {
  opacity: 0.85;
}

.tag {
  display: inline-block;
  background: linear-gradient(135deg, #EFF6FF, #EDE9FE);
  color: var(--color-primary);
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  font-weight: 600;
  border: 2rpx solid rgba(139,92,246,0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Decorative bubble */
.bubble {
  display: inline-block;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  padding: 12rpx 28rpx;
  border-radius: 28rpx 28rpx 28rpx 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: var(--shadow-clay);
}

/* Colorful tag variants */
.tag-orange  { background: #FFF7ED; color: #EA580C; }
.tag-blue    { background: #EFF6FF; color: #2563EB; }
.tag-pink    { background: #FDF2F8; color: #DB2777; }
.tag-mint    { background: #ECFDF5; color: #059669; }
.tag-yellow  { background: #FFFBEB; color: #D97706; }
.tag-purple  { background: #F5F3FF; color: #7C3AED; }

/* Vant Weapp theme overrides */
page {
  --button-primary-background-color: #3B82F6;
  --button-primary-border-color: #3B82F6;
  --tabs-bottom-bar-color: #3B82F6;
  --tabs-default-color: #3B82F6;
  --tag-primary-color: #3B82F6;
  --rate-icon-full-color: #3B82F6;
  --field-input-text-color: #1E293B;
  --uploader-upload-background-color: #F0F7FF;
  --progress-color: linear-gradient(90deg, #3B82F6, #60A5FA);
  --loading-spinner-color: #3B82F6;
  --empty-description-color: #64748B;
}
