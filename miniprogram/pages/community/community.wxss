/* pages/community/community.wxss — Cute Pet Claymorphism */
.community-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--gradient-page);
}

/* Vant Tabs override */
.clay-tabs {
  background: transparent !important;
}

/* Feed */
.feed-list,
.activity-list {
  flex: 1;
  padding: 16rpx 0;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.post-card {
  background: var(--gradient-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 12rpx 28rpx;
}

.post-header {
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-clay);
}

.user-meta {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.post-meta-row {
  gap: 12rpx;
  margin-top: 6rpx;
}

.pet-tag {
  font-weight: 600;
}

.post-time {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.post-content {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
  margin-bottom: 18rpx;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
}

/* Actions */
.post-actions {
  border-top: 2rpx solid var(--color-border);
  padding-top: 18rpx;
  gap: 40rpx;
}

.post-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  font-size: inherit;
}

.post-action::after {
  border: none;
}

.action-count {
  font-size: 24rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}

.post-action.liked .action-count {
  color: #3B82F6;
  font-weight: 700;
}

.share-action {
  margin-left: auto;
}

/* Activity Cards */
.activity-card {
  background: var(--gradient-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 12rpx 28rpx;
  overflow: hidden;
}

.activity-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.activity-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.activity-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #EFF6FF, #F0F7FF);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-inset);
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 14rpx;
  background: var(--color-border);
  border-radius: 7rpx;
  overflow: hidden;
  box-shadow: var(--shadow-inset);
}

.progress-fill {
  height: 100%;
  background: var(--gradient-primary);
  border-radius: 7rpx;
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.progress-label {
  font-size: 22rpx;
  color: var(--color-text-hint);
  font-weight: 600;
  white-space: nowrap;
}

.join-btn {
  margin-top: 8rpx;
}

/* FAB 发布按钮 */
.fab-publish {
  position: fixed;
  right: 36rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: var(--color-primary);
  box-shadow: 0 8rpx 28rpx rgba(59,130,246,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.2s;
}

.fab-publish:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.25);
}
