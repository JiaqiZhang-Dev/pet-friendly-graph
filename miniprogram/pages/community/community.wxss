/* pages/community/community.wxss — 可爱趣味风 */
.community-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

/* Tabs */
.tabs {
  display: flex;
  background: #FFFCF7;
  padding: 0 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(139,111,94,0.04);
}

.tab-item {
  position: relative;
  padding: 28rpx 36rpx;
  font-size: 30rpx;
  color: var(--color-text-hint);
  transition: color 0.2s;
  font-weight: 500;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 700;
}

.tab-underline {
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 8rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
}

/* Feed */
.feed-list,
.activity-list {
  flex: 1;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.post-card {
  margin-bottom: 4rpx;
}

.post-header {
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-meta {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.post-meta-row {
  gap: 12rpx;
  margin-top: 6rpx;
}

.pet-type-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: var(--radius-xl);
  font-weight: 600;
}

.post-time {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.post-content {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
  margin-bottom: 18rpx;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
}

/* 互动栏 */
.post-actions {
  border-top: 1rpx solid var(--color-border);
  padding-top: 18rpx;
  gap: 40rpx;
}

.post-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  font-size: inherit;
}

.post-action::after {
  border: none;
}

.action-emoji {
  font-size: 28rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.post-action.liked .action-emoji {
  transform: scale(1.2);
}

.action-count {
  font-size: 24rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}

.post-action.liked .action-count {
  color: var(--color-danger);
  font-weight: 600;
}

.share-action {
  margin-left: auto;
}

/* Activity */
.activity-card {
  margin-bottom: 4rpx;
  overflow: hidden;
}

.activity-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 18rpx;
}

.activity-info {
  margin-bottom: 18rpx;
}

.info-row {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.activity-desc {
  display: block;
  font-size: 26rpx;
  color: #6B5E50;
  line-height: 1.7;
  margin-bottom: 24rpx;
  background: var(--color-primary-light);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
}

.progress-bar {
  height: 12rpx;
  background: var(--color-border);
  border-radius: 6rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-mint));
  border-radius: 6rpx;
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.join-btn {
  width: 100%;
  border-radius: var(--radius-xl) !important;
}
