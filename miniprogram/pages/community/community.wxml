<!--pages/community/community.wxml-->
<view class="community-page">
  <!-- 顶部 Tab -->
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="onSwitchTab"
    >
      <text>{{item.label}}</text>
      <view wx:if="{{activeTab === item.key}}" class="tab-underline"></view>
    </view>
  </view>

  <!-- 动态流 -->
  <scroll-view wx:if="{{activeTab === 'feed'}}" class="feed-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:for="{{posts}}" wx:key="id" class="post-card card">
      <!-- 用户信息 -->
      <view class="post-header flex-row">
        <view class="user-avatar">
          <text>🧑</text>
        </view>
        <view class="user-meta">
          <text class="user-name">{{item.userName}}</text>
          <view class="post-meta-row flex-row">
            <text class="pet-type-tag">{{item.petType}}</text>
            <text class="post-time">{{item.createTime}}</text>
          </view>
        </view>
      </view>

      <!-- 内容 -->
      <text class="post-content">{{item.content}}</text>

      <!-- 图片占位 -->
      <view wx:if="{{item.images.length > 0}}" class="post-images">
        <image
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          class="post-image"
          src="{{img}}"
          mode="aspectFill"
        />
      </view>

      <!-- 互动栏 -->
      <view class="post-actions flex-row">
        <view
          class="post-action {{item.isLiked ? 'liked' : ''}}"
          data-index="{{index}}"
          bindtap="onLikePost"
        >
          <text class="action-emoji">{{item.isLiked ? '❤️' : '🤍'}}</text>
          <text class="action-count">{{item.likes}}</text>
        </view>
        <view class="post-action">
          <text class="action-emoji">💬</text>
          <text class="action-count">{{item.comments}}</text>
        </view>
        <button class="post-action share-action" open-type="share">
          <text class="action-emoji">📤</text>
          <text class="action-count">分享</text>
        </button>
      </view>
    </view>
  </scroll-view>

  <!-- 线下活动 -->
  <scroll-view wx:if="{{activeTab === 'activity'}}" class="activity-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:for="{{activities}}" wx:key="id" class="activity-card card">
      <text class="activity-title">{{item.title}}</text>
      <view class="activity-info">
        <text class="info-row">📅 {{item.date}}</text>
        <text class="info-row">📍 {{item.location}}</text>
        <text class="info-row">👥 {{item.participants}}/{{item.maxParticipants}} 人已报名</text>
      </view>
      <text class="activity-desc">{{item.description}}</text>

      <!-- 进度条 -->
      <view class="progress-bar">
        <view
          class="progress-fill"
          style="width: {{item.participants / item.maxParticipants * 100}}%"
        ></view>
      </view>

      <button
        class="{{item.isJoined ? 'btn-secondary' : 'btn-primary'}} join-btn"
        data-index="{{index}}"
        bindtap="onJoinActivity"
      >
        {{item.isJoined ? '取消报名' : '立即报名'}}
      </button>
    </view>
  </scroll-view>
</view>
