<!--pages/community/community.wxml — Cute Pet Claymorphism-->
<view class="community-page">
  <!-- Vant Tabs -->
  <van-tabs
    active="{{ activeTabIndex }}"
    bind:change="onTabChange"
    color="#3B82F6"
    title-active-color="#3B82F6"
    title-inactive-color="#94A3B8"
    line-width="28px"
    line-height="4px"
    custom-class="clay-tabs"
  >
    <van-tab title="动态">
      <scroll-view class="feed-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:for="{{posts}}" wx:key="id" class="post-card">
          <!-- User info -->
          <view class="post-header flex-row">
            <view class="user-avatar">
              <van-icon name="friends" size="22px" color="#3B82F6" />
            </view>
            <view class="user-meta">
              <text class="user-name">{{item.userName}}</text>
              <view class="post-meta-row flex-row">
                <van-tag round color="#EFF6FF" text-color="#3B82F6" custom-class="pet-tag">{{item.petType}}</van-tag>
                <text class="post-time">{{item.createTime}}</text>
              </view>
            </view>
          </view>

          <!-- Content -->
          <text class="post-content">{{item.content}}</text>

          <!-- Images -->
          <view wx:if="{{item.images.length > 0}}" class="post-images">
            <image
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:key="*this"
              class="post-image"
              src="{{img}}"
              mode="aspectFill"
            />
          </view>

          <!-- Actions -->
          <view class="post-actions flex-row">
            <view
              class="post-action {{item.isLiked ? 'liked' : ''}}"
              data-index="{{index}}"
              bindtap="onLikePost"
            >
              <van-icon name="{{item.isLiked ? 'like' : 'like-o'}}" size="18px" color="{{item.isLiked ? '#3B82F6' : '#94A3B8'}}" />
              <text class="action-count">{{item.likes}}</text>
            </view>
            <view class="post-action">
              <van-icon name="chat-o" size="18px" color="#94A3B8" />
              <text class="action-count">{{item.comments}}</text>
            </view>
            <button class="post-action share-action" open-type="share">
              <van-icon name="share-o" size="18px" color="#94A3B8" />
              <text class="action-count">分享</text>
            </button>
          </view>
        </view>
      </scroll-view>
    </van-tab>

    <van-tab title="线下活动">
      <scroll-view class="activity-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:for="{{activities}}" wx:key="id" class="activity-card">
          <text class="activity-title">{{item.title}}</text>
          <view class="activity-info">
            <view class="info-row">
              <van-icon name="calendar-o" size="15px" color="#3B82F6" />
              <text class="info-text">{{item.date}}</text>
            </view>
            <view class="info-row">
              <van-icon name="location-o" size="15px" color="#3B82F6" />
              <text class="info-text">{{item.location}}</text>
            </view>
            <view class="info-row">
              <van-icon name="friends-o" size="15px" color="#3B82F6" />
              <text class="info-text">{{item.participants}}/{{item.maxParticipants}} 人已报名</text>
            </view>
          </view>
          <text class="activity-desc">{{item.description}}</text>

          <!-- Progress bar -->
          <view class="progress-wrap">
            <view class="progress-bar">
              <view
                class="progress-fill"
                style="width: {{item.participants / item.maxParticipants * 100}}%"
              ></view>
            </view>
            <text class="progress-label">{{item.participants}}/{{item.maxParticipants}}</text>
          </view>

          <van-button
            type="{{item.isJoined ? 'default' : 'primary'}}"
            round
            block
            custom-class="join-btn"
            data-index="{{index}}"
            bind:click="onJoinActivity"
          >
            {{item.isJoined ? '取消报名' : '立即报名'}}
          </van-button>
        </view>
      </scroll-view>
    </van-tab>
  </van-tabs>
</view>
