/* pages/add-place/add-place.wxss — Modern Pet Claymorphism */
.add-page {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg);
}

.upload-section,
.form-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-bottom: 28rpx;
}

.upload-area {
  width: 100%;
  min-height: 420rpx;
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  transition: all 0.2s;
  box-shadow: var(--shadow-inset);
}

.upload-area:active {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}

.preview-image {
  width: 100%;
  height: 420rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 100rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 700;
}

.upload-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* Loading */
.analyzing-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  margin: 16rpx 28rpx;
  text-align: center;
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 48rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* Form */
.form-card {
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 8rpx 16rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-inset);
  border: 2rpx solid var(--color-border);
}

.clay-field {
  background: transparent !important;
}

.clay-label {
  color: var(--color-text) !important;
  font-weight: 700 !important;
}

.field-divider {
  height: 2rpx;
  background: var(--color-border);
  margin: 0 16rpx;
}

.picker-group {
  padding: 16rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 14rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  background: #FFF;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx 16rpx;
}

.submit-btn {
  margin-top: 32rpx;
}
