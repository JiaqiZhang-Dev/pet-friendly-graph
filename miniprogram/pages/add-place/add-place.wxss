/* pages/add-place/add-place.wxss — 可爱趣味风 */
.add-page {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg);
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-bottom: 28rpx;
}

.upload-area {
  width: 100%;
  min-height: 420rpx;
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFCF7;
  transition: all 0.2s;
}

.upload-area:active {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}

.preview-image {
  width: 100%;
  height: 420rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 100rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.upload-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* 加载动画 */
.analyzing {
  text-align: center;
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 48rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid var(--color-border);
  border-top: 5rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  background: #FFFCF7;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  background: #FFFCF7;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
}

.submit-btn {
  margin-top: 48rpx;
  width: 100%;
  border-radius: var(--radius-xl) !important;
}
