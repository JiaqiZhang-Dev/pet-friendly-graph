/* pages/add-place/add-place.wxss — AI添加地点 */
.add-page {
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: var(--color-bg);
}

/* 模式切换 */
.mode-tabs {
  display: flex;
  margin: 16rpx 28rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 8rpx;
  gap: 8rpx;
}

.mode-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 0;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  transition: all 0.25s;
}

.mode-tab-active {
  background: var(--color-primary);
  color: #FFF;
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.25);
}

/* 输入区域 */
.input-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-bottom: 28rpx;
}

/* 文字输入 */
.text-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-inset);
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 8rpx;
}

.analyze-btn {
  margin-top: 24rpx;
}

/* 图片上传 */
.upload-area {
  width: 100%;
  min-height: 420rpx;
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  transition: all 0.2s;
  box-shadow: var(--shadow-inset);
}

.upload-area:active {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}

.preview-image {
  width: 100%;
  height: 420rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 700;
}

.upload-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* Loading */
.analyzing-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  margin: 16rpx 28rpx;
  text-align: center;
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 48rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* Form */
.form-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.form-card {
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 8rpx 16rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-inset);
  border: 2rpx solid var(--color-border);
}

.clay-field {
  background: transparent !important;
}

.clay-label {
  color: var(--color-text) !important;
  font-weight: 700 !important;
}

.field-divider {
  height: 2rpx;
  background: var(--color-border);
  margin: 0 16rpx;
}

.picker-group {
  padding: 16rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 14rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  background: #FFF;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

/* 标签区域 */
.tag-card {
  padding: 24rpx;
}

.tag-hint {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-bottom: 20rpx;
}

.preset-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.preset-tag {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: #FFF;
  border: 2rpx solid var(--color-border);
  transition: all 0.2s;
}

.preset-tag-active {
  background: var(--color-primary);
  color: #FFF;
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.2);
}

/* 自定义标签输入 */
.custom-tag-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.custom-tag-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  background: #FFF;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-full);
}

.custom-tag-add {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-border);
  transition: all 0.2s;
}

.custom-tag-add-active {
  background: var(--color-primary);
  color: #FFF;
}

/* 已选标签预览 */
.selected-tags-preview {
  border-top: 2rpx solid var(--color-border);
  padding-top: 20rpx;
}

.selected-label {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-bottom: 12rpx;
  display: block;
}

.selected-tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-tag-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: var(--color-primary-light);
  border: 2rpx solid rgba(59,130,246,0.15);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.tag-remove {
  font-size: 28rpx;
  color: var(--color-text-hint);
  line-height: 1;
  padding: 0 4rpx;
}

.submit-btn {
  margin-top: 32rpx;
}
