<!--pages/add-place/add-place.wxml — Modern Pet Claymorphism-->
<view class="add-page">
  <view class="upload-section">
    <text class="section-title">📸 上传截图</text>
    <text class="tip-text">上传地点截图，AI 将自动识别地点信息</text>

    <view class="upload-area" bindtap="onChooseImage">
      <image
        wx:if="{{imageUrl}}"
        class="preview-image"
        src="{{imageUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击上传截图</text>
        <text class="upload-hint">支持拍照或从相册选择</text>
      </view>
    </view>
  </view>

  <!-- Analyzing -->
  <view wx:if="{{isAnalyzing}}" class="analyzing-section">
    <view class="loading-wrapper">
      <van-loading size="48rpx" color="#F97316" />
      <text class="loading-text">🤖 AI 正在识别中...</text>
    </view>
  </view>

  <!-- Results form -->
  <view wx:if="{{extractedInfo && !isAnalyzing}}" class="form-section">
    <text class="section-title">✏️ 确认信息</text>

    <view class="form-card">
      <van-field
        value="{{extractedInfo.name}}"
        label="地点名称"
        placeholder="请输入地点名称"
        border="{{false}}"
        bind:change="onNameInput"
        custom-class="clay-field"
        label-class="clay-label"
      />
      <view class="field-divider"></view>
      <van-field
        value="{{extractedInfo.address}}"
        label="地址"
        placeholder="请输入地址"
        border="{{false}}"
        bind:change="onAddressInput"
        custom-class="clay-field"
        label-class="clay-label"
      />
    </view>

    <view class="form-card">
      <view class="picker-group">
        <text class="form-label">类型</text>
        <picker
          mode="selector"
          range="{{placeTypes}}"
          range-key="label"
          value="{{selectedTypeIndex}}"
          bindchange="onTypeChange"
        >
          <view class="form-picker">
            <text>{{placeTypes[selectedTypeIndex].label}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-card" wx:if="{{extractedInfo.tags.length > 0}}">
      <text class="form-label">标签</text>
      <view class="place-tags">
        <text wx:for="{{extractedInfo.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <van-button
      type="primary"
      round
      block
      loading="{{isSubmitting}}"
      loading-text="提交中..."
      custom-class="submit-btn"
      bind:click="onSubmit"
    >
      确认添加 🐾
    </van-button>
  </view>
</view>
