<!--pages/add-place/add-place.wxml-->
<view class="add-page">
  <view class="card">
    <text class="section-title">📸 上传截图</text>
    <text class="tip-text">上传地点截图，AI 将自动识别地点信息</text>

    <view class="upload-area" bindtap="onChooseImage">
      <image
        wx:if="{{imageUrl}}"
        class="preview-image"
        src="{{imageUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击上传截图</text>
        <text class="upload-hint">支持拍照或从相册选择</text>
      </view>
    </view>
  </view>

  <!-- 分析中 -->
  <view wx:if="{{isAnalyzing}}" class="card analyzing">
    <view class="loading-wrapper">
      <view class="loading-spinner"></view>
      <text class="loading-text">🤖 AI 正在识别中...</text>
    </view>
  </view>

  <!-- 识别结果 -->
  <view wx:if="{{extractedInfo && !isAnalyzing}}" class="card">
    <text class="section-title">✏️ 确认信息</text>

    <view class="form-group">
      <text class="form-label">地点名称</text>
      <input
        class="form-input"
        value="{{extractedInfo.name}}"
        bindinput="onNameInput"
        placeholder="请输入地点名称"
      />
    </view>

    <view class="form-group">
      <text class="form-label">地址</text>
      <input
        class="form-input"
        value="{{extractedInfo.address}}"
        bindinput="onAddressInput"
        placeholder="请输入地址"
      />
    </view>

    <view class="form-group">
      <text class="form-label">类型</text>
      <picker
        mode="selector"
        range="{{placeTypes}}"
        range-key="label"
        value="{{selectedTypeIndex}}"
        bindchange="onTypeChange"
      >
        <view class="form-picker">
          <text>{{placeTypes[selectedTypeIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">标签</text>
      <view class="place-tags">
        <text wx:for="{{extractedInfo.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <button
      class="btn-primary submit-btn"
      bindtap="onSubmit"
      disabled="{{isSubmitting}}"
    >
      {{isSubmitting ? '提交中...' : '确认添加'}}
    </button>
  </view>
</view>
