/* pages/map/map.wxss — Modern Pet Claymorphism */
.map-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: var(--color-bg);
}

/* ===== Search Bar ===== */
.search-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: rgba(255,247,237,0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  gap: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #FFF;
  border-radius: var(--radius-xl);
  padding: 18rpx 28rpx;
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
}

.search-clear {
  font-size: 24rpx;
  color: var(--color-text-hint);
  padding: 8rpx 12rpx;
}

.add-btn {
  width: 84rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4rpx 4rpx 16rpx rgba(249,115,22,0.25), -2rpx -2rpx 8rpx rgba(255,255,255,0.50);
  transition: all 0.2s ease-out;
}

.add-btn:active {
  transform: scale(0.92);
  box-shadow: 2rpx 2rpx 8rpx rgba(249,115,22,0.20);
}

.add-btn-icon {
  font-size: 36rpx;
  filter: brightness(10);
}

/* ===== Filter Bar ===== */
.filter-bar {
  position: fixed;
  top: calc(108rpx + env(safe-area-inset-top));
  left: 0;
  right: 0;
  z-index: 99;
  white-space: nowrap;
  padding: 12rpx 20rpx;
  background: rgba(255,247,237,0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  margin-right: 14rpx;
  border-radius: var(--radius-lg);
  background: #FFF;
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.filter-chip.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 4rpx 4rpx 16rpx rgba(249,115,22,0.25), -2rpx -2rpx 8rpx rgba(255,255,255,0.40);
  border-color: transparent;
  transform: scale(1.05);
}

.chip-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.chip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}

.filter-chip.active .chip-label {
  color: #fff;
  font-weight: 700;
}

/* ===== Map ===== */
.map-container {
  flex: 1;
  position: relative;
}

.pet-map {
  width: 100%;
  height: 100vh;
}

/* ===== FAB Buttons ===== */
.fab-group {
  position: fixed;
  right: 28rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 98;
}

.fab-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
  transition: all 0.2s ease-out;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 2rpx 2rpx 6rpx rgba(249,115,22,0.08);
}

.fab-emoji {
  font-size: 40rpx;
}

.fab-accent {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 4rpx 4rpx 16rpx rgba(249,115,22,0.30), -2rpx -2rpx 8rpx rgba(255,255,255,0.40);
  border-color: transparent;
}

/* ===== Bottom Hint Pill ===== */
.map-hint-pill {
  position: fixed;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #FFF;
  padding: 16rpx 36rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
  z-index: 98;
}

.hint-paw {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* ===== List View ===== */
.list-container {
  flex: 1;
  padding-top: calc(190rpx + env(safe-area-inset-top));
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 16rpx 32rpx;
}

.list-title-row {
  display: flex;
  flex-direction: column;
}

.list-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-text);
}

.list-subtitle {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

.switch-map-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 12rpx 28rpx;
  border-radius: var(--radius-xl);
  font-weight: 700;
  box-shadow: var(--shadow-clay);
  border: 2rpx solid rgba(249,115,22,0.08);
}

.place-list {
  height: calc(100vh - 350rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  padding-bottom: 160rpx;
}

/* ===== Place Cards ===== */
.place-card {
  background: #FFF;
  border-radius: var(--radius-md);
  margin: 16rpx 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  transition: all 0.2s ease-out;
}

.place-card:active {
  transform: scale(0.98);
  box-shadow: 2rpx 2rpx 8rpx rgba(249,115,22,0.06);
}

.card-accent-bar {
  height: 8rpx;
  background: linear-gradient(90deg, #F97316, #FB923C, #FBBF24);
  border-radius: 4rpx 4rpx 0 0;
}

.card-body {
  padding: 28rpx 32rpx;
}

.card-top {
  margin-bottom: 12rpx;
}

.card-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.place-name {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text);
}

.place-type-badge {
  font-size: 24rpx;
}

.rating-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #FFFBEB;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-xl);
  box-shadow: 2rpx 2rpx 8rpx rgba(245,158,11,0.10), -1rpx -1rpx 4rpx rgba(255,255,255,0.60);
  border: 2rpx solid rgba(245,158,11,0.10);
}

.rating-star {
  font-size: 22rpx;
}

.rating-num {
  font-size: 26rpx;
  font-weight: 800;
  color: #D97706;
}

.place-addr {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 14rpx;
  display: block;
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid var(--color-border);
}

.footer-meta {
  font-size: 22rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}

.footer-dot {
  font-size: 18rpx;
  color: var(--color-border);
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-hint);
}
