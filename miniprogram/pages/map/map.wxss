/* pages/map/map.wxss — Cute Pet Claymorphism */
.map-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: var(--gradient-page);
}

/* ===== Top Gradient Backdrop ===== */
.top-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 97;
  background: linear-gradient(180deg, 
    rgba(255,255,255,0.95) 0%, 
    rgba(255,255,255,0.88) 40%, 
    rgba(255,255,255,0.6) 70%, 
    rgba(255,255,255,0) 100%);
  pointer-events: none;
}

/* ===== 1. Banner Bar ===== */
.banner-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 102;
  padding-left: 24rpx;
}

.banner-swiper {
  height: 100%;
}

.banner-card {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 24rpx;
  gap: 18rpx;
  border-radius: 20rpx;
  margin-right: 8rpx;
  position: relative;
  overflow: hidden;
}

.banner-blue   { background: linear-gradient(135deg, #3B82F6, #60A5FA); }
.banner-purple { background: linear-gradient(135deg, #8B5CF6, #A78BFA); }
.banner-cyan   { background: linear-gradient(135deg, #06B6D4, #22D3EE); }

.banner-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.banner-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFF;
  line-height: 1.3;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.88);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

/* Paw decorations inside banner cards */
.paw-deco {
  position: absolute;
  pointer-events: none;
  opacity: 0.12;
}
.paw-b1 { right: 20rpx; top: -6rpx; font-size: 56rpx; transform: rotate(-20deg); }
.paw-b2 { right: 30rpx; bottom: -8rpx; font-size: 48rpx; transform: rotate(15deg); }
.paw-b3 { right: 16rpx; top: -4rpx; font-size: 52rpx; transform: rotate(-30deg); }

/* ===== 2. Search Bar ===== */
.search-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 101;
  display: flex;
  align-items: center;
  padding: 8rpx 24rpx;
  gap: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.92);
  border-radius: var(--radius-full);
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.10);
  border: 2rpx solid rgba(59,130,246,0.06);
  gap: 12rpx;
}

.search-vicon {
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.25);
  transition: all 0.2s ease-out;
  flex-shrink: 0;
}

.add-btn:active {
  transform: scale(0.92);
}

/* ===== 3. Filter Bar ===== */
.filter-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  white-space: nowrap;
  padding: 6rpx 20rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 26rpx;
  margin-right: 12rpx;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.92);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.12);
  border: 2rpx solid rgba(59,130,246,0.08);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.filter-chip.active {
  background: var(--gradient-primary);
  box-shadow: 0 6rpx 20rpx rgba(59,130,246,0.25);
  border-color: transparent;
  transform: scale(1.05);
}

.chip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-left: 6rpx;
}

.filter-chip.active .chip-label {
  color: #FFF;
  font-weight: 700;
}

.chip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E3A5F;
  margin-left: 6rpx;
}

.filter-chip.active .chip-label {
  color: #2563EB;
  font-weight: 700;
}

/* ===== Map ===== */
.map-container {
  flex: 1;
  position: relative;
}

.pet-map {
  width: 100%;
  height: 100vh;
}

/* ===== FAB Buttons ===== */
.fab-group {
  position: fixed;
  right: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 101;
  transition: bottom 0.3s ease-out;
}

.fab-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  background: var(--gradient-card);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
  transition: all 0.2s ease-out;
}

.fab-btn:active {
  transform: scale(0.9);
}

/* ===== Bottom Sheet ===== */
.bottom-sheet {
  position: fixed;
  bottom: calc(130rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border-radius: 36rpx 36rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(59,130,246,0.10);
  transition: height 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  overflow: hidden;
}

.sheet-handle {
  padding: 20rpx 32rpx 16rpx;
  cursor: pointer;
  min-height: 80rpx;
}

.sheet-handle-bar {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #DBEAFE;
  margin: 0 auto 16rpx;
}

.sheet-handle-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.panel-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
  flex: 1;
}

.panel-count {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 700;
  background: #EFF6FF;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

/* Unified vertical list inside sheet */
.sheet-list {
  height: calc(100% - 120rpx);
  padding: 0 8rpx;
}

/* ===== Place Cards ===== */
.place-card {
  background: var(--gradient-card);
  border-radius: var(--radius-md);
  margin: 16rpx 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  transition: all 0.2s ease-out;
}

.place-card:active {
  transform: scale(0.98);
}

.place-card-active {
  border-color: var(--color-primary);
  box-shadow: 0 8rpx 28rpx rgba(59,130,246,0.18);
}

.card-accent-bar {
  height: 8rpx;
  background: var(--gradient-primary);
  border-radius: 4rpx 4rpx 0 0;
}

.card-body {
  padding: 28rpx 32rpx;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.place-name {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text);
  flex: 1;
}

.rating-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  box-shadow: 2rpx 2rpx 8rpx rgba(245,158,11,0.08);
  border: 2rpx solid rgba(245,158,11,0.08);
  flex-shrink: 0;
}

.rating-num {
  font-size: 26rpx;
  font-weight: 800;
  color: #D97706;
}

.place-addr-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 14rpx;
}

.place-dist {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 700;
  flex-shrink: 0;
}

.place-dot {
  font-size: 20rpx;
  color: var(--color-border);
}

.place-addr {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid var(--color-border);
}

.tap-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 14rpx;
  padding: 10rpx 0;
  color: #3B82F6;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(59,130,246,0.06);
  border-radius: 12rpx;
}

.footer-meta {
  font-size: 22rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}

.footer-dot {
  font-size: 18rpx;
  color: var(--color-border);
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 12rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.list-bottom-spacer {
  height: 120rpx;
}
