<!--pages/map/map.wxml-->
<view class="map-page">
  <!-- 顶部白色渐变遮罩背景 -->
  <view class="top-backdrop" style="height: {{filterTop + 120}}px;"></view>

  <!-- 1. Banner 轮播 — 顶部独立区域 -->
  <view class="banner-bar" style="padding-top: {{navTop}}px; height: {{navHeight + 44}}px; padding-right: {{capsuleRight}}px; box-sizing: content-box;">
    <swiper class="banner-swiper" autoplay circular interval="{{6000}}" duration="{{600}}" indicator-dots="{{false}}">
      <swiper-item>
        <view class="banner-card banner-blue">
          <view class="banner-icon-wrap"><van-icon name="smile-o" size="20px" color="#FFF" /></view>
          <view class="banner-text">
            <text class="banner-title">每日宠物小知识</text>
            <text class="banner-desc">遛狗最佳时间是清晨和傍晚哦~</text>
          </view>
          <view class="paw-deco paw-b1">🐾</view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-card banner-purple">
          <view class="banner-icon-wrap"><van-icon name="fire-o" size="20px" color="#FFF" /></view>
          <view class="banner-text">
            <text class="banner-title">热门推荐</text>
            <text class="banner-desc">本周新增 3 个宠物友好餐厅！</text>
          </view>
          <view class="paw-deco paw-b2">🐾</view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-card banner-cyan">
          <view class="banner-icon-wrap"><van-icon name="gem-o" size="20px" color="#FFF" /></view>
          <view class="banner-text">
            <text class="banner-title">AI 智能推荐</text>
            <text class="banner-desc">为毛孩找到最近友好地点~</text>
          </view>
          <view class="paw-deco paw-b3">🐾</view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 2. 搜索栏 — 独立浮层 -->
  <view class="search-bar" style="top: {{searchTop}}px;">
    <view class="search-box">
      <van-icon name="search" size="16px" color="#94A3B8" custom-class="search-vicon" />
      <input
        class="search-input"
        placeholder="搜索宠物友好地点..."
        placeholder-style="color:#94A3B8"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <van-icon wx:if="{{searchValue}}" name="clear" size="16px" color="#94A3B8" bindtap="onSearchClear" />
    </view>
    <view class="add-btn" bindtap="goAddPlace">
      <van-icon name="photograph" size="20px" color="#FFF" />
    </view>
  </view>

  <!-- 3. 分类筛选 — 独立浮层 -->
  <scroll-view class="filter-bar" style="top: {{filterTop}}px;" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{placeTypes}}"
      wx:key="key"
      class="filter-chip {{selectedType === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="onFilterType"
    >
      <van-icon name="{{item.iconName}}" size="16px" color="{{selectedType === item.key ? '#FFF' : '#3B82F6'}}" />
      <text class="chip-label">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 地图区域 -->
  <view class="map-container">
    <map
      id="petMap"
      class="pet-map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      polyline="{{[]}}"
      show-location
      enable-zoom
      enable-scroll
      enable-rotate="{{false}}"
      bindmarkertap="onMarkerTap"
      bindregionchange="onRegionChange"
    />

    <!-- 浮动操作按钮 -->
    <view class="fab-group" style="bottom: calc({{panelHeight}}rpx + 160rpx);">
      <view class="fab-btn" bindtap="moveToLocation">
        <van-icon name="aim" size="22px" color="#3B82F6" />
      </view>
    </view>
  </view>

  <!-- WXS for smooth drag on render thread -->
  <wxs src="./sheet-drag.wxs" module="drag" />

  <!-- 底部可拉起面板 -->
  <view
    class="bottom-sheet sheet-{{panelState}}"
    style="height: {{panelHeight}}rpx;"
  >
    <!-- 拖拽把手 — 只在这里拦截触摸做拖拽 -->
    <view
      class="sheet-handle"
      bindtap="onSheetHandleTap"
      catchtouchstart="{{drag.touchstart}}"
      catchtouchmove="{{drag.touchmove}}"
      catchtouchend="{{drag.touchend}}"
    >
      <view class="sheet-handle-bar"></view>
      <view class="sheet-handle-row">
        <text class="panel-title">附近宠物友好地点</text>
        <text class="panel-count">{{filteredPlaces.length}} 个</text>
        <van-icon name="{{panelState === 'full' ? 'arrow-down' : 'arrow-up'}}" size="14px" color="#94A3B8" />
      </view>
    </view>

    <!-- 统一垂直列表 -->
    <scroll-view
      class="sheet-list"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
    >
      <view
        wx:for="{{filteredPlaces}}"
        wx:key="id"
        class="place-card {{activePlace === item.id ? 'place-card-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPlaceTap"
      >
        <view class="card-layout">
          <view class="card-left-bar" style="background: {{item.typeColor}};"></view>
          <view class="card-body">
            <view class="card-top">
              <text class="place-name">{{item.name}}</text>
              <view class="type-badge" style="background: {{item.typeColor}}20; border-color: {{item.typeColor}}30;">
                <van-icon name="{{item.typeIcon}}" size="16px" color="{{item.typeColor}}" />
              </view>
            </view>
            <view class="place-addr-row">
              <van-icon name="location-o" size="13px" color="#94A3B8" />
              <text class="place-dist">{{item.distanceText}}</text>
              <text class="place-dot">·</text>
              <text class="place-addr">{{item.address}}</text>
            </view>
            <view class="place-tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
            </view>
            <view class="card-footer">
              <van-icon name="star" size="13px" color="#F59E0B" />
              <text class="rating-num">{{item.rating}}</text>
              <van-icon name="chat-o" size="13px" color="#94A3B8" />
              <text class="footer-meta">{{item.reviewCount}} 条评价</text>
              <text class="footer-dot">·</text>
              <van-icon name="clock-o" size="13px" color="#94A3B8" />
              <text class="footer-meta">{{item.openTime}}</text>
            </view>
            <view wx:if="{{activePlace === item.id}}" class="tap-hint">
              <text>再次点击查看详情</text>
              <van-icon name="arrow" size="12px" color="#8B5CF6" />
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{filteredPlaces.length === 0}}" class="empty-state">
        <van-icon name="search" size="60px" color="#DBEAFE" />
        <text class="empty-title">暂无符合条件的地点</text>
        <text class="empty-hint">试试换个筛选条件吧~</text>
      </view>
      <view class="list-bottom-spacer"></view>
    </scroll-view>
  </view>
</view>
