<!--pages/map/map.wxml-->
<view class="map-page">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <van-icon name="search" size="16px" color="#94A3B8" custom-class="search-vicon" />
      <input
        class="search-input"
        placeholder="搜索宠物友好地点..."
        placeholder-style="color:#94A3B8"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <van-icon wx:if="{{searchValue}}" name="clear" size="16px" color="#94A3B8" bindtap="onSearchClear" />
    </view>
    <view class="add-btn" bindtap="goAddPlace">
      <van-icon name="photograph" size="22px" color="#FFF" />
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{placeTypes}}"
      wx:key="key"
      class="filter-chip {{selectedType === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="onFilterType"
    >
      <van-icon name="{{item.iconName}}" size="16px" color="{{selectedType === item.key ? '#FFF' : '#3B82F6'}}" />
      <text class="chip-label">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 地图区域 -->
  <view class="map-container" wx:if="{{!showList}}">
    <map
      id="petMap"
      class="pet-map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      show-location
      enable-zoom
      enable-scroll
      enable-rotate="{{false}}"
      bindmarkertap="onMarkerTap"
      bindregionchange="onRegionChange"
    />

    <!-- 浮动操作按钮组 -->
    <view class="fab-group">
      <view class="fab-btn" bindtap="moveToLocation">
        <van-icon name="aim" size="22px" color="#3B82F6" />
      </view>
      <view class="fab-btn" bindtap="goNearby">
        <van-icon name="shop-o" size="22px" color="#3B82F6" />
      </view>
      <view class="fab-btn fab-accent" bindtap="toggleListView">
        <van-icon name="bars" size="22px" color="#FFF" />
      </view>
    </view>
  </view>

  <!-- 底部地点面板 — 按距离排序自动展示（独立于 map-container） -->
  <view class="bottom-panel" wx:if="{{!showList}}">
    <view class="panel-header">
      <view class="panel-indicator"></view>
      <text class="panel-title">附近宠物友好地点</text>
      <text class="panel-count">{{filteredPlaces.length}} 个</text>
    </view>
    <scroll-view
      class="panel-scroll"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollToPlaceId}}"
      scroll-with-animation
    >
      <view
        wx:for="{{filteredPlaces}}"
        wx:key="id"
        id="place-{{item.id}}"
        class="panel-card {{activePlace === item.id ? 'panel-card-active' : ''}}"
        data-id="{{item.id}}"
        data-lat="{{item.latitude}}"
        data-lng="{{item.longitude}}"
        bindtap="onPanelCardTap"
      >
        <view class="panel-card-top">
          <text class="panel-card-name">{{item.name}}</text>
          <view class="panel-card-rating">
            <van-icon name="star" size="12px" color="#F59E0B" />
            <text class="panel-rating-num">{{item.rating}}</text>
          </view>
        </view>
        <view class="panel-card-meta">
          <van-icon name="location-o" size="12px" color="#94A3B8" />
          <text class="panel-card-dist">{{item.distanceText}}</text>
          <text class="panel-card-dot">·</text>
          <text class="panel-card-type">{{item.typeLabel}}</text>
        </view>
        <view class="panel-card-tags">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}" class="panel-tag">{{tag}}</text>
        </view>
        <view class="panel-card-bottom">
          <van-icon name="chat-o" size="12px" color="#94A3B8" />
          <text class="panel-card-reviews">{{item.reviewCount}} 评价</text>
          <text class="panel-card-dot">·</text>
          <van-icon name="clock-o" size="12px" color="#94A3B8" />
          <text class="panel-card-time">{{item.openTime}}</text>
        </view>
      </view>
      <view wx:if="{{filteredPlaces.length === 0}}" class="panel-empty">
        <van-icon name="search" size="32px" color="#DBEAFE" />
        <text class="panel-empty-text">暂无附近地点</text>
      </view>
    </scroll-view>
  </view>

  <!-- 列表视图 -->
  <view class="list-container" wx:else>
    <view class="list-header">
      <view class="list-title-row">
        <text class="list-title">{{filteredPlaces.length}} 个好去处</text>
        <text class="list-subtitle">按距离排序 · 带毛孩子出门啦~</text>
      </view>
      <view class="switch-map-btn" bindtap="toggleListView">
        <van-icon name="location-o" size="14px" color="#3B82F6" />
        <text>地图</text>
      </view>
    </view>

    <scroll-view class="place-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{filteredPlaces}}"
        wx:key="id"
        class="place-card"
        data-id="{{item.id}}"
        bindtap="onPlaceTap"
      >
        <view class="card-accent-bar"></view>
        <view class="card-body">
          <view class="card-top flex-between">
            <view class="card-name-row">
              <text class="place-name">{{item.name}}</text>
            </view>
            <view class="rating-badge">
              <van-icon name="star" size="12px" color="#F59E0B" />
              <text class="rating-num">{{item.rating}}</text>
            </view>
          </view>
          <view class="place-addr-row">
            <van-icon name="location-o" size="13px" color="#94A3B8" />
            <text class="place-addr">{{item.distanceText}} · {{item.address}}</text>
          </view>
          <view class="place-tags">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
          </view>
          <view class="card-footer">
            <van-icon name="chat-o" size="13px" color="#94A3B8" />
            <text class="footer-meta">{{item.reviewCount}} 条评价</text>
            <text class="footer-dot">·</text>
            <van-icon name="clock-o" size="13px" color="#94A3B8" />
            <text class="footer-meta">{{item.openTime}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{filteredPlaces.length === 0}}" class="empty-state">
        <van-icon name="search" size="60px" color="#DBEAFE" />
        <text class="empty-title">暂无符合条件的地点</text>
        <text class="empty-hint">试试换个筛选条件吧~</text>
      </view>
    </scroll-view>
  </view>
</view>
