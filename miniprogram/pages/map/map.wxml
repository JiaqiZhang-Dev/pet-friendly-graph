<!--pages/map/map.wxml-->
<view class="map-page">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索宠物友好地点..."
        placeholder-style="color:#C4B5A5"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text wx:if="{{searchValue}}" class="search-clear" bindtap="onSearchClear">✕</text>
    </view>
    <view class="add-btn" bindtap="goAddPlace">
      <text class="add-btn-icon">📸</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{placeTypes}}"
      wx:key="key"
      class="filter-chip {{selectedType === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="onFilterType"
    >
      <text class="chip-icon">{{item.icon}}</text>
      <text class="chip-label">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 地图区域 -->
  <view class="map-container" wx:if="{{!showList}}">
    <map
      id="petMap"
      class="pet-map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      show-location
      enable-zoom
      enable-scroll
      enable-rotate="{{false}}"
      bindmarkertap="onMarkerTap"
    />

    <!-- 浮动操作按钮组 -->
    <view class="fab-group">
      <view class="fab-btn" bindtap="moveToLocation">
        <text class="fab-emoji">📍</text>
      </view>
      <view class="fab-btn" bindtap="goNearby">
        <text class="fab-emoji">🏥</text>
      </view>
      <view class="fab-btn fab-accent" bindtap="toggleListView">
        <text class="fab-emoji">📋</text>
      </view>
    </view>

    <!-- 底部提示胶囊 -->
    <view class="map-hint-pill">
      <text class="hint-paw">🐾</text>
      <text class="hint-text">发现 {{filteredPlaces.length}} 个宠物友好地点</text>
    </view>
  </view>

  <!-- 列表视图 -->
  <view class="list-container" wx:else>
    <view class="list-header">
      <view class="list-title-row">
        <text class="list-title">{{filteredPlaces.length}} 个好去处</text>
        <text class="list-subtitle">带毛孩子出门啦~ 🎉</text>
      </view>
      <view class="switch-map-btn" bindtap="toggleListView">
        <text>🗺 地图</text>
      </view>
    </view>

    <scroll-view class="place-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{filteredPlaces}}"
        wx:key="id"
        class="place-card"
        data-id="{{item.id}}"
        bindtap="onPlaceTap"
      >
        <!-- 类型色带 -->
        <view class="card-accent-bar"></view>
        <view class="card-body">
          <view class="card-top flex-between">
            <view class="card-name-row">
              <text class="place-name">{{item.name}}</text>
              <text class="place-type-badge">{{item.type === 'mall' ? '🏬' : item.type === 'restaurant' ? '🍽' : item.type === 'cafe' ? '☕' : item.type === 'park' ? '🌳' : item.type === 'hotel' ? '🏨' : item.type === 'pet-store' ? '🛒' : '🏥'}}</text>
            </view>
            <view class="rating-badge">
              <text class="rating-star">⭐</text>
              <text class="rating-num">{{item.rating}}</text>
            </view>
          </view>
          <text class="place-addr">📍 {{item.address}}</text>
          <view class="place-tags">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
          </view>
          <view class="card-footer">
            <text class="footer-meta">💬 {{item.reviewCount}} 条评价</text>
            <text class="footer-dot">·</text>
            <text class="footer-meta">🕐 {{item.openTime}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{filteredPlaces.length === 0}}" class="empty-state">
        <text class="empty-icon">🐾</text>
        <text class="empty-title">暂无符合条件的地点</text>
        <text class="empty-hint">试试换个筛选条件吧~</text>
      </view>
    </scroll-view>
  </view>
</view>
