/* pages/profile/profile.wxss — Cute Pet Claymorphism */
.profile-page {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background: var(--gradient-page);
}

.profile-header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 48rpx;
  background: var(--gradient-primary);
  border-radius: 0 0 60rpx 60rpx;
  overflow: hidden;
}

.header-deco-1 {
  position: absolute;
  left: 24rpx;
  top: 40rpx;
  font-size: 80rpx;
  opacity: 0.12;
}

.header-deco-2 {
  position: absolute;
  right: 40rpx;
  top: 60rpx;
  font-size: 56rpx;
  opacity: 0.12;
}

.header-deco-3 {
  position: absolute;
  right: 32rpx;
  bottom: 24rpx;
  font-size: 64rpx;
  opacity: 0.12;
}

.avatar-wrapper {
  margin-bottom: 20rpx;
  position: relative;
}

.avatar-btn-hidden {
  position: absolute;
  width: 176rpx;
  height: 176rpx;
  opacity: 0;
  z-index: 2;
  padding: 0;
  margin: 0;
}

.avatar-circle {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid rgba(255,255,255,0.6);
  box-shadow: 6rpx 6rpx 24rpx rgba(59,130,246,0.25), -4rpx -4rpx 12rpx rgba(255,255,255,0.40);
  box-sizing: border-box;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.3);
}

.avatar-emoji {
  font-size: 72rpx;
}

.nick-name {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.profile-bubble {
  background: rgba(255,255,255,0.3);
  padding: 10rpx 28rpx;
  border-radius: 28rpx 28rpx 28rpx 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  backdrop-filter: blur(8px);
}

/* Stats */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: -24rpx;
  margin-left: 28rpx;
  margin-right: 28rpx;
  padding: 36rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 800;
  color: #3B82F6;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 8rpx;
  font-weight: 600;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--color-border);
  border-radius: 1rpx;
}

/* 我的宠物 */
.pet-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 28rpx 28rpx 24rpx;
  margin: 24rpx 28rpx;
}

.pet-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.pet-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.pet-add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-light);
}

.pet-add-text {
  font-size: 24rpx;
  color: #3B82F6;
  font-weight: 600;
}

.pet-empty {
  padding: 32rpx 0;
  text-align: center;
}

.pet-empty-text {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.pet-scroll {
  white-space: nowrap;
}

.pet-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 4rpx;
}

.pet-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  padding: 20rpx 12rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-inset);
}

.pet-card-add {
  border-style: dashed;
}

.pet-avatar-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.pet-avatar-add {
  background: var(--color-bg) !important;
  border: 2rpx dashed var(--color-border);
}

.pet-avatar-emoji {
  font-size: 48rpx;
}

.pet-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140rpx;
}

.pet-breed {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

.add-label {
  color: var(--color-text-hint);
  font-weight: 500;
}

/* Menu */
.menu-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 12rpx 28rpx;
  margin: 24rpx 28rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--color-border);
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--color-primary-light);
  margin: 0 -28rpx;
  padding: 28rpx;
  border-radius: var(--radius-md);
}

.menu-left {
  gap: 20rpx;
}

.menu-icon-circle {
  width: 68rpx;
  height: 68rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 3rpx 3rpx 10rpx rgba(59,130,246,0.06), -2rpx -2rpx 6rpx rgba(255,255,255,0.70);
}

.menu-icon {
  font-size: 32rpx;
}

.menu-label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* 添加宠物弹窗 */
.add-pet-popup {
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 20rpx;
  flex-shrink: 0;
}

.popup-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 36rpx;
  max-height: 60vh;
}

.popup-footer {
  padding: 24rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  background: #FFF;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text);
}

.popup-close {
  padding: 8rpx;
}

.popup-field {
  margin-bottom: 28rpx;
}

.popup-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.popup-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}

.species-chips {
  display: flex;
  gap: 20rpx;
}

.species-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  transition: all 0.2s;
}

.species-chip-active {
  border-color: #3B82F6;
  background: #EFF6FF;
  color: #3B82F6;
  box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.15);
}

.species-emoji {
  font-size: 48rpx;
}

.breed-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.breed-chip {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  transition: all 0.2s;
}

.breed-chip-active {
  background: #3B82F6;
  color: #FFF;
  border-color: #3B82F6;
  box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.2);
}

.gender-chips {
  display: flex;
  gap: 20rpx;
}

.gender-chip {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  transition: all 0.2s;
}

.gender-male {
  border-color: #3B82F6;
  background: #EFF6FF;
  color: #3B82F6;
}

.gender-female {
  border-color: #EC4899;
  background: #FDF2F8;
  color: #EC4899;
}

.popup-submit {
  margin-top: 12rpx;
}
