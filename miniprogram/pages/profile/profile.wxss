/* pages/profile/profile.wxss — 可爱趣味风 */
.profile-page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background: var(--color-bg);
}

.profile-header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
  background: linear-gradient(160deg, #6B9E7A 0%, #9AD5CA 50%, #E8F5E9 100%);
  border-radius: 0 0 60rpx 60rpx;
  overflow: hidden;
}

.header-deco-left {
  position: absolute;
  left: 24rpx;
  top: 40rpx;
  font-size: 80rpx;
  opacity: 0.15;
}

.header-deco-right {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  font-size: 64rpx;
  opacity: 0.15;
}

.avatar-wrapper {
  margin-bottom: 20rpx;
}

.avatar-btn {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  background: none;
  border: 8rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 8rpx 32rpx rgba(107,158,122,0.25);
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.3);
}

.avatar-emoji {
  font-size: 72rpx;
}

.nick-name {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.profile-bubble {
  background: rgba(255,255,255,0.3);
  padding: 10rpx 28rpx;
  border-radius: 28rpx 28rpx 28rpx 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
}

/* 统计 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: -24rpx;
  margin-left: 28rpx;
  margin-right: 28rpx;
  padding: 36rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 8rpx;
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--color-border);
  border-radius: 1rpx;
}

/* 菜单 */
.menu-section {
  padding: 12rpx 28rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--color-primary-light);
  margin: 0 -28rpx;
  padding: 28rpx;
  border-radius: var(--radius-md);
}

.menu-left {
  gap: 20rpx;
}

.menu-icon-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--color-text-hint);
  font-weight: 300;
}
