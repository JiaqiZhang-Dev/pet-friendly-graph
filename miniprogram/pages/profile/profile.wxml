<!--pages/profile/profile.wxml — Cute Pet Claymorphism-->
<view class="profile-page">
  <!-- Header -->
  <view class="profile-header">
    <view class="avatar-wrapper">
      <button class="avatar-btn-hidden" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar"></button>
      <view class="avatar-circle" bindtap="onTapAvatar">
        <image
          wx:if="{{userInfo.avatarUrl}}"
          class="avatar-img"
          src="{{userInfo.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <van-icon name="friends" size="36px" color="#FFF" />
        </view>
      </view>
    </view>
    <text class="nick-name">{{userInfo.nickName}}</text>
    <view class="profile-bubble">
      <text>探索宠物友好的美好世界</text>
    </view>
  </view>

  <!-- Stats -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{stats.places}}</text>
      <text class="stat-label">添加地点</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.reviews}}</text>
      <text class="stat-label">评价</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.activities}}</text>
      <text class="stat-label">参与活动</text>
    </view>
  </view>

  <!-- 我的宠物 -->
  <view class="pet-section">
    <view class="pet-section-header">
      <text class="pet-section-title">我的宠物</text>
      <view class="pet-add-btn" bindtap="onAddPet">
        <van-icon name="plus" size="14px" color="#3B82F6" />
        <text class="pet-add-text">添加</text>
      </view>
    </view>

    <view wx:if="{{pets.length === 0}}" class="pet-empty">
      <text class="pet-empty-text">还没有添加宠物，快来添加你的毛孩子吧~</text>
    </view>

    <scroll-view wx:else class="pet-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="pet-list">
        <view wx:for="{{pets}}" wx:key="id" class="pet-card" bindtap="onEditPet" data-index="{{index}}">
          <view class="pet-avatar-circle" style="background: {{item.color}}15;">
            <text class="pet-avatar-emoji">{{item.emoji}}</text>
          </view>
          <text class="pet-name">{{item.name}}</text>
          <text class="pet-breed">{{item.breed}}</text>
        </view>
        <view class="pet-card pet-card-add" bindtap="onAddPet">
          <view class="pet-avatar-circle pet-avatar-add">
            <van-icon name="plus" size="28px" color="#94A3B8" />
          </view>
          <text class="pet-name add-label">添加宠物</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 添加宠物弹窗 -->
  <van-popup
    show="{{showAddPet}}"
    position="bottom"
    round
    bind:close="onCloseAddPet"
  >
    <view class="add-pet-popup">
      <view class="popup-header">
        <text class="popup-title">添加宠物</text>
        <view class="popup-close" bindtap="onCloseAddPet">
          <van-icon name="cross" size="18px" color="#94A3B8" />
        </view>
      </view>

      <scroll-view class="popup-scroll" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- 昵称 -->
      <view class="popup-field">
        <text class="popup-label">宠物昵称</text>
        <input
          class="popup-input"
          value="{{petForm.name}}"
          placeholder="给你的毛孩子取个名字"
          bindinput="onPetNameInput"
          maxlength="10"
        />
      </view>

      <!-- 类型 -->
      <view class="popup-field">
        <text class="popup-label">宠物类型</text>
        <view class="species-chips">
          <view
            wx:for="{{speciesList}}"
            wx:key="key"
            class="species-chip {{petForm.species === item.key ? 'species-chip-active' : ''}}"
            bindtap="onSelectSpecies"
            data-key="{{item.key}}"
          >
            <text class="species-emoji">{{item.emoji}}</text>
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 品种 -->
      <view wx:if="{{petForm.species}}" class="popup-field">
        <text class="popup-label">品种</text>
        <view class="breed-chips">
          <view
            wx:for="{{breedOptions}}"
            wx:key="*this"
            class="breed-chip {{petForm.breed === item ? 'breed-chip-active' : ''}}"
            bindtap="onSelectBreed"
            data-breed="{{item}}"
          >
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 性别 -->
      <view class="popup-field">
        <text class="popup-label">性别</text>
        <view class="gender-chips">
          <view
            class="gender-chip {{petForm.gender === '公' ? 'gender-chip-active gender-male' : ''}}"
            bindtap="onSelectGender"
            data-gender="公"
          >
            <text>♂ 弟弟</text>
          </view>
          <view
            class="gender-chip {{petForm.gender === '母' ? 'gender-chip-active gender-female' : ''}}"
            bindtap="onSelectGender"
            data-gender="母"
          >
            <text>♀ 妹妹</text>
          </view>
        </view>
      </view>
      </scroll-view>

      <view class="popup-footer">
        <van-button
          type="primary"
          round
          block
          custom-class="popup-submit"
          disabled="{{!petForm.name || !petForm.breed}}"
          bind:click="onConfirmAddPet"
        >
          确认添加 🐾
        </van-button>
      </view>
    </view>
  </van-popup>

  <!-- Menu -->
  <view class="menu-section">
    <view
      wx:for="{{menuItems}}"
      wx:key="key"
      class="menu-item"
      data-key="{{item.key}}"
      bindtap="onMenuTap"
    >
      <view class="menu-left flex-row">
        <view class="menu-icon-circle" style="background: {{item.bgColor || '#EFF6FF'}}">
          <van-icon name="{{item.iconName}}" size="18px" color="{{item.iconColor || '#3B82F6'}}" />
        </view>
        <text class="menu-label">{{item.label}}</text>
      </view>
      <van-icon name="arrow" color="#94A3B8" size="14px" />
    </view>
  </view>
</view>
