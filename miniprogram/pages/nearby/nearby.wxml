<!--pages/nearby/nearby.wxml — Modern Pet Claymorphism-->
<view class="nearby-page">
  <!-- Type tabs -->
  <view class="type-tabs">
    <view
      wx:for="{{facilityTypes}}"
      wx:key="key"
      class="type-tab {{selectedType === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="onSwitchType"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-text">{{item.label}}</text>
    </view>
  </view>

  <!-- View toggle -->
  <view class="view-toggle" bindtap="toggleView">
    <text wx:if="{{showMap}}">📋 列表模式</text>
    <text wx:else>🗺 地图模式</text>
  </view>

  <!-- Map -->
  <map
    wx:if="{{showMap}}"
    class="nearby-map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="13"
    markers="{{markers}}"
    show-location
  />

  <!-- List -->
  <scroll-view wx:else class="facility-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{facilities}}"
      wx:key="id"
      class="facility-card"
      data-id="{{item.id}}"
      bindtap="onFacilityTap"
    >
      <view class="facility-accent"></view>
      <view class="facility-info">
        <view class="flex-between">
          <text class="facility-name">{{item.name}}</text>
          <view class="facility-rating">
            <text class="rating-icon">⭐</text>
            <text class="rating-val">{{item.rating}}</text>
          </view>
        </view>
        <text class="facility-address">📍 {{item.address}}</text>
        <view class="facility-tags">
          <van-tag
            wx:for="{{item.tags}}"
            wx:for-item="tag"
            wx:key="*this"
            round
            size="medium"
            color="#EFF6FF"
            text-color="#3B82F6"
          >{{tag}}</van-tag>
        </view>
        <text class="facility-meta">💬 {{item.reviewCount}} 条评价 · 🕐 {{item.openTime}}</text>
      </view>
    </view>

    <van-empty wx:if="{{facilities.length === 0}}" description="附近暂无该类设施" />
  </scroll-view>
</view>
