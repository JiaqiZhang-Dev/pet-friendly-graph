/* pages/nearby/nearby.wxss — 可爱趣味风 */
.nearby-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

.type-tabs {
  display: flex;
  background: #FFFCF7;
  padding: 20rpx 28rpx;
  gap: 24rpx;
}

.type-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: #FFF;
  box-shadow: var(--shadow-card);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.type-tab.active {
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(107,158,122,0.3);
  transform: scale(1.03);
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 600;
}

.type-tab.active .tab-text {
  color: #fff;
}

.view-toggle {
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background: #FFFCF7;
  font-weight: 600;
}

.nearby-map {
  flex: 1;
  width: 100%;
}

.facility-list {
  flex: 1;
}

.facility-card {
  margin-bottom: 4rpx;
}

.facility-name {
  font-size: 30rpx;
  font-weight: 700;
  flex: 1;
  color: var(--color-text);
}

.facility-rating {
  font-size: 26rpx;
  color: var(--color-warning);
  background: #FFF9E6;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-xl);
  font-weight: 600;
}

.facility-address {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin: 10rpx 0 14rpx;
}

.facility-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.facility-meta {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-hint);
}
