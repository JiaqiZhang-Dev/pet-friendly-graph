/* pages/nearby/nearby.wxss — Modern Pet Claymorphism */
.nearby-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

.type-tabs {
  display: flex;
  background: var(--color-bg);
  padding: 20rpx 28rpx;
  gap: 24rpx;
}

.type-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: #FFF;
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.type-tab.active {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  color: #fff;
  box-shadow: 4rpx 4rpx 16rpx rgba(59,130,246,0.25), -2rpx -2rpx 8rpx rgba(255,255,255,0.40);
  border-color: transparent;
  transform: scale(1.03);
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
}

.type-tab.active .tab-text {
  color: #fff;
}

.view-toggle {
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-bg);
  font-weight: 700;
}

.nearby-map {
  flex: 1;
  width: 100%;
}

.facility-list {
  flex: 1;
  padding: 8rpx 0;
}

.facility-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  margin: 12rpx 28rpx;
  overflow: hidden;
  transition: all 0.2s ease-out;
}

.facility-card:active {
  transform: scale(0.98);
}

.facility-accent {
  height: 6rpx;
  background: linear-gradient(90deg, #3B82F6, #60A5FA, #93C5FD);
}

.facility-info {
  padding: 28rpx 32rpx;
}

.facility-name {
  font-size: 30rpx;
  font-weight: 800;
  flex: 1;
  color: var(--color-text);
}

.facility-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #FFFBEB;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-xl);
  box-shadow: 2rpx 2rpx 6rpx rgba(245,158,11,0.08);
  border: 2rpx solid rgba(245,158,11,0.08);
}

.rating-icon {
  font-size: 22rpx;
}

.rating-val {
  font-size: 26rpx;
  color: #D97706;
  font-weight: 800;
}

.facility-address {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin: 12rpx 0 14rpx;
}

.facility-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.facility-meta {
  font-size: 22rpx;
  color: var(--color-text-hint);
  font-weight: 500;
}
