/* pages/place-detail/place-detail.wxss — Modern Pet Claymorphism */
.detail-page {
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg);
}

/* Hero */
.detail-hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 40%, #FBBF24 80%, #FFF7ED 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-name {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #FFF;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.hero-rating {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 8rpx;
}

.hero-deco-1 {
  position: absolute;
  right: 28rpx;
  top: 36rpx;
  font-size: 100rpx;
  opacity: 0.15;
  z-index: 0;
}

.hero-deco-2 {
  position: absolute;
  left: 60rpx;
  bottom: 20rpx;
  font-size: 60rpx;
  opacity: 0.10;
  z-index: 0;
}

/* Level card */
.level-card {
  margin-top: -16rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-clay);
  border: var(--border-clay);
  padding: 32rpx;
  margin-left: 28rpx;
  margin-right: 28rpx;
}

.level-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.level-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-tag {
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* Info card */
.info-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 8rpx 32rpx;
  margin: 16rpx 28rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
}

.info-emoji {
  font-size: 30rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex: 1;
}

/* Description */
.desc-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.description {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.9;
  display: block;
}

/* Actions */
.actions-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.action-grid {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.action-item::after {
  border: none;
}

.share-btn {
  font-size: inherit;
}

.action-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease-out;
  box-shadow: var(--shadow-clay);
}

.action-circle:active {
  transform: scale(0.9);
}

.action-orange { background: #FFF1E6; }
.action-blue   { background: #EFF6FF; }
.action-pink   { background: #FDF2F8; }

.action-emoji {
  font-size: 40rpx;
}

.action-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
}

/* Reviews */
.reviews-section {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  border: var(--border-clay);
  padding: 32rpx;
  margin: 16rpx 28rpx;
}

.review-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  margin-bottom: 14rpx;
  gap: 14rpx;
}

.review-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF1E6, #FFEDD5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 3rpx 3rpx 8rpx rgba(249,115,22,0.08);
}

.review-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.review-user-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
}

.review-date {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* Review bubble */
.review-bubble {
  background: var(--color-primary-light);
  padding: 20rpx 24rpx;
  border-radius: 4rpx 24rpx 24rpx 24rpx;
  margin-left: 86rpx;
  box-shadow: var(--shadow-inset);
}

.review-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  display: block;
}
