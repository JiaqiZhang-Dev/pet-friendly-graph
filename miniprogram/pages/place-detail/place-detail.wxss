/* pages/place-detail/place-detail.wxss — 可爱趣味风 */
.detail-page {
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg);
}

/* ===== 顶部主视觉 ===== */
.detail-hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #6B9E7A 0%, #9AD5CA 60%, #E8F5E9 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-name {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #FFF;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.hero-rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.hero-star {
  font-size: 26rpx;
}

.hero-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFF;
}

.hero-count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 8rpx;
}

.hero-deco {
  position: absolute;
  right: 28rpx;
  top: 36rpx;
  font-size: 100rpx;
  opacity: 0.2;
  z-index: 0;
}

/* ===== 等级卡片 ===== */
.level-card {
  margin-top: -16rpx;
}

.level-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.level-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.level-paws {
  font-size: 28rpx;
  letter-spacing: 6rpx;
}

/* ===== 信息卡片 ===== */
.info-card {
  padding: 24rpx 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.info-item:last-child {
  border-bottom: none;
}

.info-emoji {
  font-size: 30rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex: 1;
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
}

.description {
  font-size: 28rpx;
  color: #6B5E50;
  line-height: 1.9;
  display: block;
}

/* ===== 操作按钮 ===== */
.actions-card {
  padding: 32rpx;
}

.action-grid {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.action-item::after {
  border: none;
}

.share-btn {
  font-size: inherit;
}

.action-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.action-circle:active {
  transform: scale(0.9);
}

.action-green { background: var(--color-primary-light); }
.action-brown { background: var(--color-accent-light); }
.action-pink  { background: #FDECF3; }

.action-emoji {
  font-size: 40rpx;
}

.action-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* ===== 评价 ===== */
.review-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  margin-bottom: 14rpx;
  gap: 14rpx;
}

.review-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.review-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.review-user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.review-date {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.review-stars {
  display: flex;
}

.mini-star {
  font-size: 20rpx;
}

/* 评论气泡 */
.review-bubble {
  background: var(--color-primary-light);
  padding: 20rpx 24rpx;
  border-radius: 4rpx 24rpx 24rpx 24rpx;
  margin-left: 86rpx;
}

.review-content {
  font-size: 26rpx;
  color: #5A4E40;
  line-height: 1.7;
  display: block;
}

.empty-review {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  gap: 12rpx;
}

.empty-emoji {
  font-size: 56rpx;
}

.empty-text {
  color: var(--color-text-hint);
  font-size: 26rpx;
}
