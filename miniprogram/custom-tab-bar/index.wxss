/* custom-tab-bar/index.wxss */
.tab-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  height: 120rpx;
  background: #FFFCF7;
  border-top: none;
  box-shadow: 0 -4rpx 24rpx rgba(139,111,94,0.06);
  padding-bottom: env(safe-area-inset-bottom);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  border-radius: 36rpx 36rpx 0 0;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 10rpx 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 52rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-label {
  font-size: 20rpx;
  color: #9E8E7E;
  margin-top: 4rpx;
  line-height: 26rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: all 0.2s;
}

.tab-item.active .tab-label {
  color: #6B9E7A;
  font-weight: 700;
}

.tab-item.active .tab-icon {
  transform: scale(1.15) translateY(-4rpx);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #6B9E7A;
  border-radius: 50%;
}
