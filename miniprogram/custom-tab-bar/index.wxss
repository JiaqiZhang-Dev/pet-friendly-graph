/* custom-tab-bar/index.wxss — Cute Simple Tab Bar */
.tab-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: none;
  box-shadow: 0 -4rpx 20rpx rgba(59,130,246,0.05);
  padding-bottom: env(safe-area-inset-bottom);
  position: fixed;
  bottom: 0;
  left: 16rpx;
  right: 16rpx;
  z-index: 999;
  border-radius: 36rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid rgba(255,255,255,0.70);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  margin-bottom: 2rpx;
}

.tab-item.active .tab-icon-wrap {
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.15);
  transform: scale(1.15) translateY(-4rpx);
}

.tab-label {
  font-size: 20rpx;
  color: #94A3B8;
  line-height: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: all 0.2s;
}

.tab-item.active .tab-label {
  color: #3B82F6;
  font-weight: 700;
}
