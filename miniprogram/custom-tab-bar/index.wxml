<!--custom-tab-bar/index.wxml-->
<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap">
      <van-icon
        name="{{selected === index ? item.activeIconName : item.iconName}}"
        size="22px"
        color="{{selected === index ? '#3B82F6' : '#94A3B8'}}"
      />
    </view>
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
